# --- WorkOS AuthKit ---
# From https://dashboard.workos.com/ (Quick start)
WORKOS_CLIENT_ID=client_01XXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=workos_api_key_placeholder
# Random string >= 32 chars. Generate with: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD=at_least_32_chars_long_random_string_xxx
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Convex (filled in automatically by `npx convex dev`) ---
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
