# --- WorkOS AuthKit ---
# From https://dashboard.workos.com/ (Quick start)
WORKOS_CLIENT_ID=client_01XXXXXXXXXXXXXXXXXXXXXXXX
WORKOS_API_KEY=workos_api_key_placeholder
# Random string >= 32 chars. Generate with: openssl rand -base64 24
WORKOS_COOKIE_PASSWORD=at_least_32_chars_long_random_string_xxx
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# --- Convex (filled in automatically by `npx convex dev`) ---
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# --- Feedback agent pipeline (Convex-side env, set via `npx convex env set`) ---
# These are read by the convex/feedbackAgent.ts internal action only.
# Anthropic API key for Claude Code CLI inside the Tensorlake sandbox.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX
# Tensorlake API key for sandbox creation/management.
# https://cloud.tensorlake.ai/
TENSORLAKE_API_KEY=tl_XXXXXXXXXXXXXXXXXXXXXXXX
# Fine-grained GitHub PAT scoped to ONLY this repo.
# Permissions: Contents: read/write, Pull requests: read/write, Metadata: read.
# Do NOT grant Workflows / Administration / Actions.
# https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXXXXXX
# Repo the agent clones, branches, and opens PRs against.
GITHUB_REPO=ReedG20/nozomio-hackathon
